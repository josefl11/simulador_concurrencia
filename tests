import threading
import time

documento = ""

def usuario(nombre, texto):
    global documento
    for letra in texto:
            documento += letra
            print(f"{nombre} escribió: {letra}")
        time.sleep(0.2)

personaA = threading.Thread(target=usuario, args=("Sebastian", "hais"))
personaB = threading.Thread(target=usuario, args=("Carla", "oag"))
personaC = threading.Thread(target=usuario, args=("Stiven", "lmo"))

personaA.start()
personaB.start()
personaC.start()

personaA.join()
personaB.join()
personaC.join()

print("\nDocumento final con Lock:", documento)

