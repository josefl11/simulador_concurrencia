import threading
import time

documento = ""
lock = threading.Lock() #permite que solo un hilo se ejecute en ese momento

def usuario(nombre, texto):
    global documento
    for letra in texto:
        with lock: 
            documento += letra
            print(f"{nombre} escribió: {letra}")
        time.sleep(0.2)
    print(f"\n{nombre} terminó de escribir\n")

personaA = threading.Thread(target=usuario, args=("Sebastian", "hamo"))
personaB = threading.Thread(target=usuario, args=("Carla", "o_is"))
personaC = threading.Thread(target=usuario, args=("Stiven", "lag"))

personaA.start()
personaB.start()
personaC.start()

personaA.join()
personaB.join()
personaC.join()

print("\nDocumento final con Lock:", documento)

total_esperado = len("hamo") + len("o_is") + len("lag")

if len(documento) == total_esperado:
    print("el documento cumple con el limite de caracteres")
else:
    print("no cumple el limite de caracteres")
